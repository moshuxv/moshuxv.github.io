{
  "name": "astro-theme-pure",
  "type": "module",
  "version": "4.0.2-beta",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build", // 简化构建命令，移除可能冲突的自定义检查
    "preview": "astro preview",
    "check": "astro check",
    "format": "prettier --write  '**/*.{js,jsx,ts,tsx,md,mdx,astro}'",
    "lint": "eslint --fix 'src/**/*.{js,ts,jsx,tsx,astro}'",
    "clean": "rm -rf .astro .vercel dist"
  },
  "engines": {
    "node": ">=18.17.1 <=22.15.0" // 明确指定兼容的 Node 版本范围
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/vercel": "^8.0.3",
    "astro": "^5.5.8", // 升级到最新的 5.x 稳定版
    "@astrojs/compiler": "^5.0.5", // 显式添加编译器依赖
    "sharp": "^0.33.5", // Vercel 必须的图片处理库
    "unocss": "^0.58.3" // 升级到更稳定的 UnoCSS 版本
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "eslint": "^9.19.0",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.4.5" // 使用与 Astro 5.x 兼容的 TS 版本
  }
}